def words_to_hex(input_string):
    words = input_string.split()
    hex_colors = []

    for word in words:
        hex_value = ''
        for char in word[:3]:
            hex_value += format(ord(char), '02x')
        if len(word) < 3:
            hex_value += '00' * (3 - len(word))
        hex_colors.append(f'#{hex_value}')

    return hex_colors
