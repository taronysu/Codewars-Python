def comfortable_word(word):
    left_hand = set("qwertasdfgzxcvb")
    right_hand = set("yuiophjklnm")
    
    last_hand = None
    
    for letter in word:
        if letter in left_hand:
            current_hand = 'left'
        elif letter in right_hand:
            current_hand = 'right'
        else:
            return False
        
        if last_hand is None:
            last_hand = current_hand
        elif last_hand == current_hand:
            return False
        last_hand = current_hand
    
    return True
