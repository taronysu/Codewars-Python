def find_quarter_notes(time_signature):
    top, bottom = map(int, time_signature.split('/'))
    
    if bottom <= 0 or (bottom & (bottom - 1)) != 0 or top < 1 or top >= 4096 or bottom >= 256:
        return None
    
    quarter_notes = (top * 4) // bottom
    
    return max(quarter_notes, 0)
